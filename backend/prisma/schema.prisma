// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYER
  CANDIDATE
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  INTERVIEW
  ACCEPTED
  REJECTED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  name         String
  role         Role      @default(CANDIDATE)
  profileImage String?
  bio          String?
  resumeUrl    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  companies    Company[]
  applications Application[]
  savedJobs    SavedJob[]
  tokens       RefreshToken[]
  jobsPosted   Job[]     @relation("EmployerJobs")
}

model Company {
  id          String    @id @default(uuid())
  name        String
  description String?
  logo        String?
  website     String?
  employerId  String
  employer    User      @relation(fields: [employerId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  jobs        Job[]
}

model Job {
  id             String    @id @default(uuid())
  title          String
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employerId     String
  employer       User      @relation("EmployerJobs", fields: [employerId], references: [id], onDelete: Cascade)
  location       String
  employmentType JobType
  workMode       WorkMode
  salary         String?
  experience     String?
  skills         String[]
  benefits       String[]
  description    String
  deadline       DateTime?
  status         String    @default("OPEN")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  applications Application[]
  savedBy      SavedJob[]
}

model Application {
  id          String            @id @default(uuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   User              @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  status      ApplicationStatus @default(PENDING)
  resumeUrl   String?
  coverLetter String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([jobId, candidateId])
}

model SavedJob {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, jobId])
}

model ScrapedJob {
  id          String    @id @default(uuid())
  source      String
  url         String    @unique
  company     String
  title       String
  description String
  skills      String[]
  location    String?
  postedDate  DateTime?
  createdAt   DateTime  @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}
